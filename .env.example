# SmartMail AI Configuration

# Server Config
HOST=0.0.0.0
PORT=8000
SECRET_KEY=super-secret-key-change-in-production-aes256
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./smartmail.db
# For production Supabase/Postgres:
# DATABASE_URL=postgresql+asyncpg://postgres:password@db.supabase.co:5432/postgres

# Redis & Upstash Cache
REDIS_URL=redis://localhost:6379/0

# Pluggable LLM Provider Settings
# Options: nvidia, openai, ollama
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-your-free-nvidia-nim-key-here
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenAI Fallback (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama Fallback (Optional Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Google OAuth & Gmail API
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
GOOGLE_PUBSUB_TOPIC=projects/your-project-id/topics/gmail-push

# CORS Settings
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000
